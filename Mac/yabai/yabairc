# Start up yabai scripting to allow transparency, space creation, space elimination and more
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

yabai -m config window_opacity on

APP_LIST="(kitty|Ghostty)"
yabai -m signal --add event=window_focused app="^${APP_LIST}$" action="yabai -m config active_window_opacity 0.95"
yabai -m signal --add event=window_focused app="^${APP_LIST}$" action="yabai -m config normal_window_opacity 0.8"
# yabai -m rule --add app="kitty" opacity=0.90

yabai -m signal --add event=window_focused app!="^${APP_LIST}$" action="yabai -m config active_window_opacity 1.0"
yabai -m signal --add event=window_focused app!="^${APP_LIST}$" action="yabai -m config normal_window_opacity 1.0"

yabai -m rule --add app="^{$APP_LIST}$" manage=on

# Different tiling options Binary Space Partitioning (BSP), Stack or Float
yabai -m config layout bsp

yabai -m config window_placement second_child

yabai -m config bottom_padding 10
yabai -m config top_padding 10
yabai -m config left_padding 10
yabai -m config right_padding 10
yabai -m config window_gap 10

# Mouse settings
# yabai -m config mouse_follows_focus autoraise 
yabai -m config mouse_modifier alt
yabai -m config mouse_action1 move
yabai -m config mouse_action2 resize

yabai -m config mouse_drop_action swap

# Applications Yabai should ignore, and not tile
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="Music" manage=off
yabai -m rule --add app="Finder" manage=off

yabai -m config external_bar all:38:00
