# Changing window focus wihtin a workspace
alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - h : yabai -m window --focus west
alt - l : yabai -m window --focus east
alt - return : open -na Ghostty.app 

# Changing the layout of a workspace
shift + alt - r : yabai -m space --rotate 270
shift + alt - y : yabai -m space --mirror y-axis 
shift + alt - x : yabai -m space --mirror x-axis
shift + alt - t : yabai -m window --toggle float --grid 4:4:1:1:2:2

# Moving window to a different workspace
shift + alt - 1 : yabai -m window --space 1;
shift + alt - 2 : yabai -m window --space 2;
shift + alt - 3 : yabai -m window --space 3;
shift + alt - 4 : yabai -m window --space 4;
shift + alt - 5 : yabai -m window --space 5;
shift + alt - 6 : yabai -m window --space 6;
shift + alt - 7 : yabai -m window --space 7;
shift + alt - 8 : yabai -m window --space 8;
shift + alt - 9 : yabai -m window --space 9;

# Switching to a space
alt - 1 : ~/.config/skhd/switch_space.sh 1;
alt - 2 : ~/.config/skhd/switch_space.sh 2;
alt - 3 : ~/.config/skhd/switch_space.sh 3;
alt - 4 : ~/.config/skhd/switch_space.sh 4;
alt - 5 : ~/.config/skhd/switch_space.sh 5;
alt - 6 : ~/.config/skhd/switch_space.sh 6;
alt - 7 : ~/.config/skhd/switch_space.sh 7;
alt - 8 : ~/.config/skhd/switch_space.sh 8;
alt - 9 : ~/.config/skhd/switch_space.sh 9;
